# AIM :-
# a sorted arrray is given...
# I must have to remove the duplicates without not creating extra array...
# return how many unique number exist...

# EDGE CASES :-
# Empty Arrays
# Only One Element
# All Elements Are The Same
# All Elements Are Unique 
# Duplicates Only At The End
# Duplicates At The Begining
# Random Patterns
# Negative NUmbers And Mixed Signs

from typing import List
class Solution:
    def RemoveDuplicates(self, nums:List[int]) -> int:
        if not nums:
            return 0
        i = 0
        for j in range(1, len(nums)):
            nums[j] != nums[j]:
                i += 1
                nums[i] = nums[j]
                print(f"Unique Number Found : {nums[j]}, placing at position {i})
        return i + 1
nums = [1,1,2,2,3,3,5,50,8,50]
soultion = Solution()
k = soultion.RemoveDuplicates(nums)
print(k, nums[:k])
            












