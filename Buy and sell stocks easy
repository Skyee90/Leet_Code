# Best time to buy and sell stocks question from leet coe easy one 
# we have to return the maximum profit from the week.
# if we cant return any profit then we need to return zero...\\

#  No specfied way mentioned so doing anyway...
from typing import List
class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        buy_price = float("inf")
        profit = 0 # \\:://
        #            //--\\
        for p in prices:
            buy_price = min(buy_price, p)
            profit = max(profit, p - buy_price)
            
        return profit

prices = [1]
solution = Solution()
max_Profit = solution.maxProfit(prices)
print("maxProfit", max_Profit)









